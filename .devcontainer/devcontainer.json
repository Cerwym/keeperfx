// KeeperFX Dev Container — Windows x86 Cross-Compile (MinGW32)
//
// Opens the repository inside the keeperfx-build-mingw32 Docker image —
// the same environment used by CI and local Docker tasks. Provides:
//   - Fully working i686-w64-mingw32 toolchain and all build dependencies
//   - Native cpptools IntelliSense against the real compiler and headers
//   - cmake + ninja available directly in the terminal
//
// Worktree-safe: uses /workspaces/ mount path (not /src) so the Dev
// Containers extension auto-detects git worktrees and mounts the main
// .git directory alongside the workspace.
//
// Usage:
//   1. Install the "Dev Containers" extension (ms-vscode-remote.remote-containers)
//   2. Cmd/Ctrl+Shift+P → "Dev Containers: Reopen in Container"
//   3. Select "KeeperFX — MinGW32 (Windows x86 cross-compile)"
//
// Inside the container, build with cmake directly — no docker compose wrapper:
//   cmake --preset windows-x86-debug   && cmake --build --preset windows-x86-debug
//   cmake --preset windows-x86-release && cmake --build --preset windows-x86-release
//
// Note: Windows .exe artifacts are cross-compiled. In-container F5 debugging
// is supported through winegdb via the "Devcontainer F5" launch profile.
// If winegdb is missing in the image, the preLaunch task prints install guidance.
{
	"name": "KeeperFX — MinGW32 (Windows x86 cross-compile)",
	"image": "ghcr.io/cerwym/keeperfx-build-mingw32:latest",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools",
				"eamodio.gitlens",
				"github.vscode-pull-request-github"
			],
			"settings": {
				"C_Cpp.default.configurationName": "Docker MinGW (Windows x86 Debug)",
				"C_Cpp.default.compileCommands": "${workspaceFolder}/out/build/windows-x86-debug/compile_commands.json",
				"C_Cpp.default.compilerPath": "/usr/bin/i686-w64-mingw32-gcc-posix",
				"C_Cpp.default.intelliSenseMode": "linux-gcc-x86",
				"C_Cpp.default.cStandard": "gnu11",
				"C_Cpp.default.cppStandard": "gnu++20",
				"cmake.configureOnOpen": false,
				"cmake.autoSelectActiveFolder": false
			}
		}
	},

	// Startup fixups for worktrees and IntelliSense:
	//   1) Repairs broken worktree git pointers inside the container when needed.
	//   2) Reconfigures or rewrites compile_commands paths only when stale.
	"postStartCommand": "bash .devcontainer/fix-git-worktree.sh && bash .devcontainer/fix-intellisense.sh windows-x86-debug"
}
