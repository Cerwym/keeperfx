#!/bin/bash
# pre-commit: Block direct commits to master.
# Master should only move via fast-forward from upstream.

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$branch" = "master" ]; then
    echo ""
    echo "  BLOCKED: You're committing directly to master."
    echo ""
    echo "  master must stay in sync with upstream (dkfans/keeperfx)."
    echo "  Branch off develop instead:"
    echo ""
    echo "    git checkout develop"
    echo "    git checkout -b feature/my-thing"
    echo ""
    echo "  To bypass (rare): git commit --no-verify"
    echo ""
    exit 1
fi
