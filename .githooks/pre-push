#!/bin/bash
# pre-push: Protect master — only allow fast-forward pushes that match upstream.
# Also warn if pushing develop to upstream (which you never want).

remote="$1"
url="$2"

while read local_ref local_sha remote_ref remote_sha; do
    # ── Protect master ──────────────────────────────────────────────────
    if [ "$remote_ref" = "refs/heads/master" ]; then
        # Allow only if local master is ancestor-or-equal of upstream/master
        upstream_sha=$(git rev-parse upstream/master 2>/dev/null)
        if [ -z "$upstream_sha" ]; then
            echo ""
            echo "  WARNING: upstream remote not configured. Cannot verify master."
            echo "  Run: git remote add upstream https://github.com/dkfans/keeperfx.git"
            echo ""
            exit 1
        fi

        # Check that the commit being pushed is reachable from upstream/master
        if ! git merge-base --is-ancestor "$local_sha" "$upstream_sha" && \
           ! [ "$local_sha" = "$upstream_sha" ]; then
            # local master is ahead of upstream — only ok if it's a ff of upstream
            if ! git merge-base --is-ancestor "$upstream_sha" "$local_sha"; then
                echo ""
                echo "  BLOCKED: master has diverged from upstream/master."
                echo "  master should only be a fast-forward of upstream."
                echo ""
                echo "    git checkout master"
                echo "    git reset --hard upstream/master"
                echo "    git push origin master"
                echo ""
                exit 1
            fi
        fi
    fi

    # ── Warn about pushing develop to upstream ──────────────────────────
    if echo "$url" | grep -q "dkfans/keeperfx"; then
        if [ "$remote_ref" = "refs/heads/develop" ]; then
            echo ""
            echo "  BLOCKED: You're pushing develop to upstream (dkfans)."
            echo "  develop contains your personal infra — don't push it upstream."
            echo "  Use tools/upstream-pr.ps1 to create a clean branch for upstream PRs."
            echo ""
            exit 1
        fi
    fi

done

exit 0
