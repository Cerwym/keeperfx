// KeeperFX Launch Configuration
//
// Prerequisites:
//   1. Docker Desktop running
//   2. Run "Init .deploy/" task once to populate game data into .deploy/
//
// F5 triggers "Build & Deploy Windows Debug" which cross-compiles via the
// mingw32 Docker container and copies the exe to .deploy/ before launching.
//
// Source file paths embedded in DWARF debug info use /src (the Docker mount
// point). The sourceFileMap below translates them back to your workspace.
{
"version": "0.2.0",
"configurations": [
{
"name": "Vita Remote Debug (GDB)",
"type": "cppdbg",
"request": "launch",
"program": "/src/out/build/vita-debug/keeperfx",
"cwd": "/src",
"MIMode": "gdb",
"miDebuggerServerAddress": "${input:vitaGdbIp}:31337",
"stopAtConnect": true,
"pipeTransport": {
    "debuggerPath": "/usr/local/vitasdk/bin/arm-vita-eabi-gdb",
    "pipeProgram": "docker",
    "pipeArgs": [
        "compose", "-f", "${workspaceFolder}/docker/compose.yml",
        "run", "--rm", "-T", "vitasdk"
    ],
    "pipeCwd": "${workspaceFolder}"
},
"setupCommands": [
    { "description": "Remote timeout for WiFi latency", "text": "set remotetimeout 10", "ignoreFailures": false },
    { "description": "Pretty print structs", "text": "set print pretty on", "ignoreFailures": true },
    { "description": "No pagination in MI mode", "text": "set pagination off", "ignoreFailures": true },
    { "description": "No confirm prompts", "text": "set confirm off", "ignoreFailures": true }
],
"sourceFileMap": { "/src": "${workspaceFolder}" },
"preLaunchTask": "Build Vita Debug",
"logging": { "moduleLoad": false }
},
{
"name": "Debug keeperfx",
"type": "cppdbg",
"request": "launch",
"program": "${workspaceFolder}/.deploy/keeperfx.exe",
"cwd": "${workspaceFolder}/.deploy",
"args": [],
"windows": {
"miDebuggerPath": "${workspaceFolder}/.vscode/gdb.exe"
},
"MIMode": "gdb",
"setupCommands": [
{ "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true },
{ "description": "Intel disassembly flavour", "text": "-gdb-set disassembly-flavor intel", "ignoreFailures": true }
],
"sourceFileMap": { "/src": "${workspaceFolder}" },
"preLaunchTask": "Build & Deploy Windows Debug",
"externalConsole": true,
"stopAtEntry": false,
"logging": { "moduleLoad": false }
}
],
"inputs": [
{
"id": "vitaGdbIp",
"type": "promptString",
"description": "PS Vita IP address for GDB remote debugging",
"default": "192.168.0.66"
}
]
}
