{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug KeeperFX (Windows Host)",
      // F5 default. Builds in container, copies exe to .deploy/, then launches + debugs on Windows host.
      // Run \"Init .deploy/\" once first to populate game data layers.
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/.deploy/keeperfx.exe",
      "cwd": "${workspaceFolder}/.deploy",
      "args": [
        "-nointro",
        "-alex"
      ],
      "MIMode": "gdb",
      "visualizerFile": "${workspaceFolder}/.vscode/keeperfx.natvis",
      "showDisplayString": true,
      "windows": {
        "miDebuggerPath": "${workspaceFolder}/.vscode/gdb.exe"
      },
      "linux": {
        "miDebuggerPath": "winegdb"
      },
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set disassembly flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        },
        {
          "description": "Improve value readability in Watch/Locals",
          "text": "-interpreter-exec console \"set print pretty on\"",
          "ignoreFailures": true
        },
        {
          "description": "Avoid truncating arrays/strings in prints",
          "text": "-interpreter-exec console \"set print elements 0\"",
          "ignoreFailures": true
        },
        {
          "description": "Stop C strings at null terminator",
          "text": "-interpreter-exec console \"set print null-stop on\"",
          "ignoreFailures": true
        },
        {
          "description": "Hide noisy array indexes in GDB prints",
          "text": "-interpreter-exec console \"set print array-indexes off\"",
          "ignoreFailures": true
        },
        {
          "description": "Load KeeperFX GDB pretty printers (char[] fields show as strings)",
          "text": "-interpreter-exec console \"python exec(open(r'${workspaceFolder}/.vscode/keeperfx-gdb-printers.py').read())\"",
          "ignoreFailures": true
        }
      ],
      "sourceFileMap": {
        "/src": "${workspaceFolder}"
      },
      "preLaunchTask": "Build & Deploy Windows Debug",
      "externalConsole": true,
      "stopAtEntry": false,
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "name": "Devcontainer F5 (Wine)",
      // Use this profile when working inside the MinGW devcontainer.
      // Builds natively with the container's own compiler (no Docker-in-Docker),
      // then launches keeperfx.exe under Wine with GDB attached.
      // One-time setup: run task \"Install Devcontainer Wine Debugger\" first.
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/.deploy/keeperfx.exe",
      "cwd": "${workspaceFolder}/.deploy",
      "args": [
        "-nointro",
        "-alex"
      ],
      "MIMode": "gdb",
      "miDebuggerPath": "${workspaceFolder}/.vscode/wine_debugger.sh",
      "visualizerFile": "${workspaceFolder}/.vscode/keeperfx.natvis",
      "showDisplayString": true,
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set disassembly flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        },
        {
          "description": "Improve value readability in Watch/Locals",
          "text": "-interpreter-exec console \"set print pretty on\"",
          "ignoreFailures": true
        },
        {
          "description": "Avoid truncating arrays/strings in prints",
          "text": "-interpreter-exec console \"set print elements 0\"",
          "ignoreFailures": true
        },
        {
          "description": "Stop C strings at null terminator",
          "text": "-interpreter-exec console \"set print null-stop on\"",
          "ignoreFailures": true
        },
        {
          "description": "Hide noisy array indexes in GDB prints",
          "text": "-interpreter-exec console \"set print array-indexes off\"",
          "ignoreFailures": true
        },
        {
          "description": "Load KeeperFX GDB pretty printers (char[] fields show as strings)",
          "text": "-interpreter-exec console \"python exec(open(r'${workspaceFolder}/.vscode/keeperfx-gdb-printers.py').read())\"",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Devcontainer F5 Prep (Windows Debug)",
      "externalConsole": false,
      "stopAtEntry": false,
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}
